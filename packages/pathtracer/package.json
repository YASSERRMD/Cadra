    "lint": "eslint src"
  },
  "dependencies": {
    "@cadra/core": "workspace:*",
    "three": "^0.185.1",
    "three-gpu-pathtracer": "^0.0.24",
    "three-mesh-bvh": "^0.9.10",
    "xatlas-web": "^0.1.0"
  },
  "devDependencies": {
    "@types/three": "^0.185.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
