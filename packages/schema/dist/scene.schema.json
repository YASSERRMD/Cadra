{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1,
      "description": "The scene document schema version this document was authored against."
    },
    "project": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this project."
        },
        "name": {
          "type": "string",
          "description": "Human-readable name of this project."
        },
        "compositions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for this composition within the project."
              },
              "name": {
                "type": "string",
                "description": "Human-readable name of this composition."
              },
              "fps": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991,
                "description": "Frames per second this composition runs at."
              },
              "durationInFrames": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991,
                "description": "Total integer length of this composition, in frames."
              },
              "width": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991,
                "description": "Output width of this composition, in pixels."
              },
              "height": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991,
                "description": "Output height of this composition, in pixels."
              },
              "tracks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Unique identifier for this track within the project."
                    },
                    "name": {
                      "description": "Optional human-readable label, purely for authoring and debugging.",
                      "type": "string"
                    },
                    "clips": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "Unique identifier for this clip within the project."
                          },
                          "startFrame": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991,
                            "description": "The frame, relative to the start of its composition, this clip begins on."
                          },
                          "durationInFrames": {
                            "type": "integer",
                            "exclusiveMinimum": 0,
                            "maximum": 9007199254740991,
                            "description": "How many frames this clip is visible for."
                          },
                          "node": {
                            "description": "The root of the scene-node subtree this clip contributes.",
                            "$ref": "#/$defs/__schema1"
                          }
                        },
                        "required": [
                          "id",
                          "startFrame",
                          "durationInFrames",
                          "node"
                        ],
                        "additionalProperties": false
                      },
                      "description": "The ordered clips placed on this track."
                    }
                  },
                  "required": [
                    "id",
                    "clips"
                  ],
                  "additionalProperties": false
                },
                "description": "The tracks of clips that populate this composition."
              }
            },
            "required": [
              "id",
              "name",
              "fps",
              "durationInFrames",
              "width",
              "height",
              "tracks"
            ],
            "additionalProperties": false
