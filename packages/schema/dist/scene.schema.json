        },
        "kind": {
          "type": "string",
          "const": "group",
          "description": "Discriminant identifying this node as a group."
        },
        "name": {
          "description": "Optional human-readable label, purely for authoring and debugging.",
          "type": "string"
        },
        "transform": {
          "type": "object",
          "properties": {
            "position": {
              "type": "array",
              "prefixItems": [
                {
                  "type": "number",
                  "description": "The x component of the vector."
                },
                {
                  "type": "number",
                  "description": "The y component of the vector."
                },
                {
                  "type": "number",
                  "description": "The z component of the vector."
                }
              ],
              "description": "World-space translation of the node."
            },
            "rotation": {
              "type": "array",
              "prefixItems": [
                {
                  "type": "number",
                  "description": "The x component of the vector."
                },
                {
                  "type": "number",
                  "description": "The y component of the vector."
                },
                {
                  "type": "number",
                  "description": "The z component of the vector."
                }
              ],
              "description": "Euler rotation in radians, applied in intrinsic XYZ order."
            },
            "scale": {
              "type": "array",
              "prefixItems": [
                {
                  "type": "number",
                  "description": "The x component of the vector."
                },
                {
                  "type": "number",
                  "description": "The y component of the vector."
                },
                {
                  "type": "number",
                  "description": "The z component of the vector."
                }
              ],
              "description": "Per-axis scale factor of the node."
            }
          },
          "required": [
            "position",
            "rotation",
            "scale"
          ],
          "additionalProperties": false,
          "description": "The position, rotation, and scale of this node."
        },
        "visible": {
          "type": "boolean",
          "description": "Whether this node (and its subtree) should be rendered."
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema1"
          },
          "description": "Child scene nodes nested under this node."
        }
      },
      "required": [
        "id",
        "kind",
        "transform",
        "visible",
        "children"
      ],
      "additionalProperties": false
    },
