                },
                {
                  "type": "number",
                  "description": "The z component of the vector."
                }
              ],
              "description": "Per-axis scale factor of the node."
            }
          },
          "required": [
            "position",
            "rotation",
            "scale"
          ],
          "additionalProperties": false,
          "description": "The position, rotation, and scale of this node."
        },
        "visible": {
          "type": "boolean",
