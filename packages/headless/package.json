{
  "name": "@cadra/headless",
  "version": "0.0.0",
  "private": false,
  "description": "Cadra headless package",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "lint": "eslint src",
    "benchmark:native-vs-browser": "node scripts/benchmark-native-vs-browser.mjs"
  },
  "dependencies": {
    "@cadra/core": "workspace:*",
    "@cadra/renderer": "workspace:*",
    "esbuild": "^0.28.1",
    "playwright": "^1.61.1",
    "three": "^0.185.1",
    "webgpu": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/three": "^0.185.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
