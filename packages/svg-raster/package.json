{
  "name": "@cadra/svg-raster",
  "version": "0.0.0",
  "private": false,
  "description": "Cadra deterministic SVG to RGBA rasterization package",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@cadra/core": "workspace:*",
    "@resvg/resvg-js": "^2.6.2"
  },
  "devDependencies": {
    "@cadra/satori-layer": "workspace:*",
    "@cadra/text": "workspace:*",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
