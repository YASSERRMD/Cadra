{
  "name": "@cadra/text",
  "version": "0.0.0",
  "private": false,
  "description": "Cadra text package",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@cadra/core": "workspace:*",
    "bidi-js": "^1.0.3",
    "fontkit": "^2.0.4",
    "harfbuzzjs": "^1.4.0",
    "maxrects-packer": "^2.7.3",
    "msdfgen-wasm": "^1.0.0",
    "opentype.js": "^2.0.0",
    "subset-font": "^2.5.0",
    "unicode-properties": "^1.4.1"
  },
  "devDependencies": {
    "@types/fontkit": "^2.0.9",
    "@types/node": "^26.1.0",
    "@types/opentype.js": "^1.3.10",
    "@types/unicode-properties": "^1.3.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
