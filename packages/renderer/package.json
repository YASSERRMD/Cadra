{
  "name": "@cadra/renderer",
  "version": "0.0.0",
  "private": false,
  "description": "Cadra renderer package",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./svg-layer/prepare-satori-layer-render-data.js": {
      "types": "./dist/svg-layer/prepare-satori-layer-render-data.d.ts",
      "default": "./dist/svg-layer/prepare-satori-layer-render-data.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@cadra/core": "workspace:*",
    "@cadra/particles": "workspace:*",
    "@cadra/pathtracer": "workspace:*",
    "@cadra/physics": "workspace:*",
    "@cadra/satori-layer": "workspace:*",
    "@cadra/svg-raster": "workspace:*",
    "@cadra/text": "workspace:*",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/three": "^0.185.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
