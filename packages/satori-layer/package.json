{
  "name": "@cadra/satori-layer",
  "version": "0.0.0",
  "private": false,
  "description": "Cadra browserless HTML/CSS to SVG 2D layer package",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@cadra/core": "workspace:*",
    "@cadra/text": "workspace:*",
    "@discordapp/twemoji": "^16.0.1",
    "lucide-static": "^1.23.0",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
