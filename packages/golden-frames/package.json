{
  "name": "@cadra/golden-frames",
  "version": "0.0.0",
  "private": false,
  "description": "Cadra golden-frame visual regression harness",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run --exclude src/compare-references.e2e.test.ts",
    "lint": "eslint src",
    "update-references": "node scripts/update-references.mjs",
    "compare-references": "vitest run src/compare-references.e2e.test.ts"
  },
  "dependencies": {
    "@cadra/core": "workspace:*",
    "@cadra/headless": "workspace:*",
    "@cadra/renderer": "workspace:*",
    "@cadra/text": "workspace:*",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/pngjs": "^6.0.5",
    "playwright": "^1.61.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
