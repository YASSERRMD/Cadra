{
  "name": "@cadra/encode",
  "version": "0.0.0",
  "private": false,
  "description": "Cadra encode package",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
